# Hedera Configuration
# Copy this file to .env and fill in your values

# Network Configuration
VITE_HEDERA_NETWORK=testnet  # or mainnet

# HCS Topic IDs
# Create these topics using the hederaService.createTreePlantingTopic() method
# or via Hedera Portal/HashScan
VITE_TREE_PLANTING_TOPIC_ID=0.0.XXXXX
VITE_VERIFICATION_TOPIC_ID=0.0.XXXXX
VITE_GAMIFICATION_TOPIC_ID=0.0.XXXXX

# HTS Token IDs
# OJZ Token - Create via Hedera Token Service
VITE_OJZ_TOKEN_ID=0.0.XXXXX

# Optional: Mirror Node API (for querying HCS messages)
VITE_MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com
